# ── E2E / Integration Test Environment ──────────────────────────────────────
# Copy this file, fill in your values, and source it before running tests.
# NEVER commit credentials to version control.

NODE_ENV=test
PORT=5050

# MONGO_URI is not needed in test mode — mongodb-memory-server is used automatically.

# JWT secret — can be anything stable for tests
ACCESS_TOKEN_SECRET=e2e-test-secret-not-for-production

# Email is not sent in test mode (nodemailer is not needed for E2E tests
# because seeded users already have emailVerifiedAt set, but set these to
# avoid startup warnings if your code references them).
EMAIL_USER=
EMAIL_PASS=
FRONTEND_URL=http://localhost:5173

# Poll interval — use a large value so the automatic loop doesn't interfere
# with the manual /api/test/trigger-poll calls in tests.
REPORT_POLL_INTERVAL_MS=3600000
